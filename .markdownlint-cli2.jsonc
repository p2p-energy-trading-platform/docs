{
  "globs": ["**/*.md"],
  "ignores": [
    "node_modules/**",
    ".git/**",
    ".confluence-publish/**"
  ],
  "config": {
    "default": true,

    // Allow long technical lines, URLs, and tables.
    "MD013": false,

    // Allow duplicate headings in different sections if needed.
    "MD024": false,

    // Front matter is expected.
    "MD041": false
  }
}